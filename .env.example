# Lead delivery via Resend (https://resend.com).
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored (see .gitignore) — never commit secrets.

# Required to send real emails. Create a free key at https://resend.com.
# When unset, submissions are logged to the server console (dev fallback).
RESEND_API_KEY=

# Verified sender address. The domain MUST be verified in your Resend account.
# Until you verify a domain, you can use Resend's test sender for your own address only.
RESEND_FROM="Manaseerz Electric <leads@manaseerz.com>"

# Inbox that receives contact-form and booking leads.
CONTACT_EMAIL="info@manaseerz.com"
